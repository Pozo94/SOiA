extends ../layout

block content
  .card
    h2 Lista adresów

    .actions
      a.button(
        href="/addresses?status=nowy"
        class=filters.status === 'nowy' && !filters.assigned && !filters.q ? '' : 'button-secondary'
      ) Nowe

      a.button(
        href="/addresses?assigned=mine"
        class=filters.assigned === 'mine' && !filters.status && !filters.q ? '' : 'button-secondary'
      ) Moje

      a.button(
        href="/addresses?status=przypisany"
        class=filters.status === 'przypisany' && !filters.assigned && !filters.q ? '' : 'button-secondary'
      ) Przypisane

      a.button(
        href="/addresses?status=zakonczony"
        class=filters.status === 'zakonczony' && !filters.assigned && !filters.q ? '' : 'button-secondary'
      ) Zakończone

      a.button.button-secondary(href="/addresses") Wszystkie

    form(action="/addresses" method="GET")
      .form-section
        h3 Filtry i wyszukiwanie

        .details-grid
          .form-group
            label(for="q") Szukaj
            input#q(
              type="text"
              name="q"
              placeholder="Skrót, tytuł, adres, miasto..."
              value=filters.q
            )

          .form-group
            label(for="status") Status
            select#status(name="status")
              option(value="") Wszystkie
              option(value="nowy" selected=filters.status === 'nowy') Nowe
              option(value="przypisany" selected=filters.status === 'przypisany') Przypisane
              option(value="zakonczony" selected=filters.status === 'zakonczony') Zakończone

          .form-group
            label(for="assigned") Przypisanie
            select#assigned(name="assigned")
              option(value="" selected=filters.assigned === '') Wszystkie
              option(value="free" selected=filters.assigned === 'free') Nieprzypisane
              option(value="assigned" selected=filters.assigned === 'assigned') Przypisane do kogokolwiek
              option(value="mine" selected=filters.assigned === 'mine') Tylko moje

          .form-group
            label(for="sort") Sortowanie
            select#sort(name="sort")
              option(value="createdAt_desc" selected=filters.sort === 'createdAt_desc') Najnowsze
              option(value="createdAt_asc" selected=filters.sort === 'createdAt_asc') Najstarsze
              option(value="shortName_asc" selected=filters.sort === 'shortName_asc') Skrót A-Z
              option(value="shortName_desc" selected=filters.sort === 'shortName_desc') Skrót Z-A
              option(value="title_asc" selected=filters.sort === 'title_asc') Tytuł A-Z
              option(value="title_desc" selected=filters.sort === 'title_desc') Tytuł Z-A
              option(value="city_asc" selected=filters.sort === 'city_asc') Miasto A-Z
              option(value="city_desc" selected=filters.sort === 'city_desc') Miasto Z-A
              option(value="status_asc" selected=filters.sort === 'status_asc') Status A-Z
              option(value="status_desc" selected=filters.sort === 'status_desc') Status Z-A

        .actions
          button(type="submit") Zastosuj
          a.button.button-secondary(href="/addresses") Wyczyść

    if !addresses.length
      p Brak adresów spełniających podane kryteria.
    else
      .table-wrap
        table
          thead
            tr
              th Skrót
              th Tytuł
              th Kategoria
              th Adres
              th Miasto
              th Status
              th Przypisany
          tbody
            each address in addresses
              tr
                td
                  a(href=`/addresses/${address._id}`)= address.shortName
                td= address.title
                td= address.category
                td= address.address
                td= address.city
                td
                  span(class=`badge badge-${address.status}`)= address.status
                td
                  if address.assignedTo
                    = address.assignedTo.username
                  else
                    form.inline-form(action=`/addresses/${address._id}/assign` method="POST")
                      button(type="submit") Przypisz do mnie